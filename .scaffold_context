    if (entity === 'risikobehandlung_&_maßnahmenplan' && fieldKey === 'massnahme_is_risiko') {
      const match = (lists.informationssicherheitsrisikenList ?? []).find((r: any) => r.record_id === id);
      return match?.fields.is_risiko_name ?? '—';
    }
    if (entity === 'risikobehandlung_&_maßnahmenplan' && fieldKey === 'massnahme_kontrolle') {
      const match = (lists.sicherheitskontrollenList ?? []).find((r: any) => r.record_id === id);
      return match?.fields.kontrolle_name ?? '—';
